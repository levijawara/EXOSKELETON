# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (required for admin-only operations like exports/audit)
SUPABASE_SERVICE_ROLE_KEY=

# Admin convenience: comma-separated emails treated as admins
ADMIN_EMAILS=

# Product mode: utility | saas | community | marketplace | internal
NEXT_PUBLIC_PRODUCT_MODE=saas

# Feature packs (optional)
NEXT_PUBLIC_PACK_BILLING=false
NEXT_PUBLIC_PACK_UGC=false
NEXT_PUBLIC_PACK_B2B=false
NEXT_PUBLIC_PACK_FILES=false
NEXT_PUBLIC_PACK_AI=false

# Dev/testing toggles (optional)
# Legacy: SKIP_AUTH=true implies utility when PRODUCT_MODE is unset
SKIP_AUTH=false
E2E_PORT=3100
E2E_RUN_INTEGRATION=false
E2E_EMAIL=
E2E_PASSWORD=

